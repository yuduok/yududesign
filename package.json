{
  "name": "yududesign",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages",
    "packages/*",
    "docs"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "docs:dev": "cd docs && pnpm dev",
    "docs:build": "cd docs && pnpm build",
    "build:components": "cd packages && pnpm build",
    "build:all": "pnpm build:components && pnpm docs:build",
    "dev:components": "cd packages && pnpm dev",
    "test": "cd packages && pnpm test",
    "test:run": "cd packages && pnpm test:run",
    "test:coverage": "cd packages && pnpm test:coverage",
    "clean": "cd packages && rm -rf dist && pnpm -r --filter='@yududesign/*' exec rm -rf lib es dist",
    "install:all": "pnpm install"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "next": "15.4.10"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "npm:@types/react@^19.0.0",
    "@types/react-dom": "npm:@types/react-dom@^19.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "npm:@types/react@^18",
      "@types/react-dom": "npm:@types/react-dom@^18",
      "react": "^18",
      "react-dom": "^18"
    }
  }
}
